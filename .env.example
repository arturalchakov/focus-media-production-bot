# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Telegram ID менеджера для уведомлений о лидах
MANAGER_CHAT_ID=123456789

# Telegram IDs администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# База данных (SQLite для MVP)
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Модель OpenAI
OPENAI_MODEL=gpt-4o

# Лимиты токенов
MAX_TOKENS_DIAGNOSIS=800
MAX_TOKENS_CONTENT=1200

# Задержки follow-up сообщений (часы)
FOLLOWUP_DELAYS_HOURS=24,48,72
